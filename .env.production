# Production — API : https://dev-rusatravel.asdc-rdc.org/api
VITE_API_ORIGIN=https://dev-rusatravel.asdc-rdc.org
# Contournement CORS temporaire (backend n'autorise pas encore X-Societe-Id)
VITE_ENABLE_SOCIETE_HEADER=0
# 1 = désactive les appels API au montage des dashboards ; 0 ou absent = activé
VITE_DISABLE_DASHBOARD_API=0
# Désactive les appels API automatiques post-login (profil/roles)
VITE_DISABLE_AUTH_BOOTSTRAP_API=1
